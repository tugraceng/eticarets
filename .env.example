# Root / shared
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/platform?schema=public"

# Backend (apps/backend)
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
# İstemci kökeni(leri). Üretimde virgülle birden fazla verebilirsiniz: "https://site.com,https://www.site.com"
# Geliştirmede localhost, 127.0.0.1 ve [::1] üzerindeki tüm portlar ayrıca kabul edilir (tarayıcı adresi farkı).
CORS_ORIGIN="http://localhost:3000"
PORT=4000

# Frontend (apps/frontend)
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
# Sunucu tarafı fetch'lerde bekleme süresi (ms); API yanıt vermezse sayfa takılı kalmayı azaltır
NEXT_PUBLIC_API_TIMEOUT_MS="12000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
# Optional: use plain localhost without subdomain (?tenant= still works)
NEXT_PUBLIC_FALLBACK_TENANT=""
